# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# France Travail API — obligatoire
# Créer une application sur https://francetravail.io/data/api
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# Anthropic — optionnel (LLM re-rank désactivé si absent)
ANTHROPIC_API_KEY=

# La Bonne Alternance — optionnel (source LBA désactivée si absent)
API_APPRENTISSAGE_KEY=

# Verbosité des logs : DEBUG, INFO, WARNING, ERROR (défaut : INFO)
LOG_LEVEL=INFO
